# Diedericks Dobermanns — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git

# Supabase (client — safe to expose with EXPO_PUBLIC_ prefix)
EXPO_PUBLIC_SUPABASE_URL=https://nlmwxodvquwbjinhhbmr.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-side only — NEVER prefix with EXPO_PUBLIC_ or import in the mobile app
# Used by Supabase Edge Functions and local scripts only:
# SUPABASE_SERVICE_ROLE_KEY=get_from_supabase_dashboard_settings_api

# Email (Resend) — server-side only
# RESEND_API_KEY=get_from_resend.com

# WhatsApp Business API — server-side only
# WHATSAPP_API_KEY=get_from_360dialog_or_twilio

# Expo Push Notifications — server-side only
# EXPO_PUSH_ACCESS_TOKEN=get_from_expo.dev

# Daily.co (video calls — Edge Function create-video-room)
# DAILY_API_KEY=get_from_daily.co
# DAILY_DOMAIN=your-daily-domain.daily.co
